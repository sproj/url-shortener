{
  "__inputs": [],
  "__requires": [],
  "annotations": {
    "list": []
  },
  "description": "k6 load test results for url-shortener \u2014 baseline and ongoing runs",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "id": 100,
      "title": "Test Overview",
      "type": "row"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "description": "Virtual users active over time. Shows the ramp-up, steady state, and ramp-down stages.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15
          },
          "unit": "short"
        }
      },
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 0,
        "y": 1
      },
      "id": 1,
      "options": {
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "expr": "k6_vus",
          "legendFormat": "Active VUs"
        },
        {
          "expr": "k6_vus_max",
          "legendFormat": "Max VUs"
        }
      ],
      "title": "Virtual Users",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "description": "Total HTTP requests completed per second across both endpoints.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15
          },
          "unit": "reqps"
        }
      },
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 8,
        "y": 1
      },
      "id": 2,
      "targets": [
        {
          "expr": "rate(k6_http_reqs_total[30s])",
          "legendFormat": "Requests/sec"
        }
      ],
      "title": "Request Rate",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "description": "Percentage of checks that passed. Should be 100% \u2014 any drop indicates application errors.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 99
              },
              {
                "color": "green",
                "value": 100
              }
            ]
          },
          "unit": "percent",
          "decimals": 1
        },
        "overrides": []
      },
      "gridPos": {
        "h": 6,
        "w": 4,
        "x": 16,
        "y": 1
      },
      "id": 3,
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto",
        "justifyMode": "center"
      },
      "targets": [
        {
          "expr": "k6_checks_rate * 100",
          "legendFormat": "Check pass rate"
        }
      ],
      "title": "Check Pass Rate",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "description": "HTTP error rate. Threshold is <1%.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.5
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          },
          "unit": "percent",
          "decimals": 2
        }
      },
      "gridPos": {
        "h": 6,
        "w": 4,
        "x": 20,
        "y": 1
      },
      "id": 4,
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto",
        "justifyMode": "center"
      },
      "targets": [
        {
          "expr": "k6_http_req_failed_rate * 100",
          "legendFormat": "Error %"
        }
      ],
      "title": "HTTP Error Rate",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 7
      },
      "id": 101,
      "title": "Shorten Endpoint \u2014 POST /shorten (Write Path)",
      "type": "row"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "description": "Latency percentiles for POST /shorten over time. The write path hits Postgres. Baseline p(95) target: <500ms.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          },
          "unit": "ms"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "id": 5,
      "targets": [
        {
          "expr": "k6_shorten_duration_ms_p50",
          "legendFormat": "p(50)"
        },
        {
          "expr": "k6_shorten_duration_ms_p90",
          "legendFormat": "p(90)"
        },
        {
          "expr": "k6_shorten_duration_ms_p95",
          "legendFormat": "p(95)"
        },
        {
          "expr": "k6_shorten_duration_ms_p99",
          "legendFormat": "p(99)"
        }
      ],
      "title": "Shorten Latency Percentiles",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "description": "Min and max shorten latency \u2014 useful for spotting outlier spikes.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 5
          },
          "unit": "ms"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "id": 6,
      "targets": [
        {
          "expr": "k6_shorten_duration_ms_min",
          "legendFormat": "min"
        },
        {
          "expr": "k6_shorten_duration_ms_max",
          "legendFormat": "max"
        }
      ],
      "title": "Shorten Latency Min / Max",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 16
      },
      "id": 102,
      "title": "Redirect Endpoint \u2014 GET /r/{code} (Read Path)",
      "type": "row"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "description": "Latency percentiles for GET /r/{code} over time. The read path hits Redis. Baseline p(95) target: <200ms. Note: redirects are measured to first byte \u2014 k6 does not follow the 301/302.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          },
          "unit": "ms"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 17
      },
      "id": 7,
      "targets": [
        {
          "expr": "k6_redirect_duration_ms_p50",
          "legendFormat": "p(50)"
        },
        {
          "expr": "k6_redirect_duration_ms_p90",
          "legendFormat": "p(90)"
        },
        {
          "expr": "k6_redirect_duration_ms_p95",
          "legendFormat": "p(95)"
        },
        {
          "expr": "k6_redirect_duration_ms_p99",
          "legendFormat": "p(99)"
        }
      ],
      "title": "Redirect Latency Percentiles",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "description": "Min and max redirect latency.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 5
          },
          "unit": "ms"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 17
      },
      "id": 8,
      "targets": [
        {
          "expr": "k6_redirect_duration_ms_min",
          "legendFormat": "min"
        },
        {
          "expr": "k6_redirect_duration_ms_max",
          "legendFormat": "max"
        }
      ],
      "title": "Redirect Latency Min / Max",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 25
      },
      "id": 103,
      "title": "Error Rates",
      "type": "row"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "description": "Per-endpoint error rates over time. Threshold: <1%. Any non-zero value here warrants investigation.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 20
          },
          "unit": "percentunit",
          "min": 0,
          "max": 1
        }
      },
      "gridPos": {
        "h": 6,
        "w": 12,
        "x": 0,
        "y": 26
      },
      "id": 9,
      "targets": [
        {
          "expr": "k6_shorten_errors_rate",
          "legendFormat": "Shorten errors"
        },
        {
          "expr": "k6_redirect_errors_rate",
          "legendFormat": "Redirect errors"
        },
        {
          "expr": "k6_http_req_failed_rate",
          "legendFormat": "All HTTP errors"
        }
      ],
      "title": "Error Rates by Endpoint",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "description": "Breakdown of time spent in each phase of the HTTP request. Useful for diagnosing whether latency is in the network (connecting, blocked) or the application (waiting = time to first byte from server).",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 10
          },
          "unit": "ms"
        }
      },
      "gridPos": {
        "h": 6,
        "w": 12,
        "x": 12,
        "y": 26
      },
      "id": 10,
      "targets": [
        {
          "expr": "k6_http_req_waiting_p95",
          "legendFormat": "Waiting (TTFB) p95"
        },
        {
          "expr": "k6_http_req_receiving_p95",
          "legendFormat": "Receiving p95"
        },
        {
          "expr": "k6_http_req_sending_p95",
          "legendFormat": "Sending p95"
        },
        {
          "expr": "k6_http_req_connecting_p95",
          "legendFormat": "Connecting p95"
        }
      ],
      "title": "HTTP Request Phase Breakdown (p95)",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 32
      },
      "id": 104,
      "title": "Baseline Reference Numbers",
      "type": "row"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "description": "Point-in-time stat panels showing the last recorded values. Use these as your baseline reference when comparing future runs.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 100
              },
              {
                "color": "red",
                "value": 500
              }
            ]
          },
          "unit": "ms"
        }
      },
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 0,
        "y": 33
